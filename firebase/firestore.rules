rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function chatMember(chatId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /chats/{chatId} {
      allow read: if chatMember(chatId);
      allow create: if signedIn() && request.auth.uid in request.resource.data.memberIds;
      allow update: if chatMember(chatId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if chatMember(chatId);
        allow create: if chatMember(chatId) && request.resource.data.senderId == request.auth.uid;
        allow update: if chatMember(chatId);
        allow delete: if false;
      }
    }
  }
}
