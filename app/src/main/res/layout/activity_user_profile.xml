<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ghost_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/ghost_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="10dp"
            android:paddingEnd="8dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/btnBackProfile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/ghost_neon"
                android:textSize="28sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Профиль"
                android:textColor="@color/ghost_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="14dp">

            <FrameLayout
                android:id="@+id/avatarContainer"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_avatar_circle">

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_avatar_circle"
                    android:clipToOutline="true"
                    android:scaleType="centerCrop"
                    android:visibility="invisible" />

                <TextView
                    android:id="@+id/tvAvatarFallback"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="G"
                    android:textColor="@color/ghost_text_primary"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Имя"
                android:textColor="@color/ghost_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvDisplayNameValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ghost_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Логин"
                android:textColor="@color/ghost_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvLoginValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ghost_text_primary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="UID"
                android:textColor="@color/ghost_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvUidValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ghost_text_primary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>
