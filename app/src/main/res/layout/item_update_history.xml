<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_card_dark"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvHistoryVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ghost_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvHistoryDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/ghost_text_secondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvHistoryTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/ghost_neon"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvHistoryChanges"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/ghost_text_primary"
        android:textSize="13sp" />
</LinearLayout>
