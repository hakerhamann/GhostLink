<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingTop="4dp"
    android:paddingEnd="10dp"
    android:paddingBottom="4dp">

    <FrameLayout
        android:id="@+id/avatarContainer"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_gravity="bottom"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_avatar_circle"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_avatar_circle"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/tvAvatarFallback"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="G"
            android:textColor="@color/ghost_text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/messageBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:background="@drawable/bg_message_incoming"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/tvSender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ghost_neon"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/replyContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input_field"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingTop="6dp"
            android:paddingEnd="8dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvReplySender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/ghost_neon"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/replyContentRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivReplyImage"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="7dp"
                    android:background="@drawable/bg_message_image"
                    android:clipToOutline="true"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvReplyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:maxWidth="205dp"
                    android:textColor="@color/ghost_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivImageMessage"
            android:layout_width="220dp"
            android:layout_height="160dp"
            android:layout_marginTop="4dp"
            android:adjustViewBounds="false"
            android:background="@drawable/bg_message_image"
            android:clipToOutline="true"
            android:contentDescription="image_message"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <android.widget.GridLayout
            android:id="@+id/photoAlbumGrid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:columnCount="2"
            android:useDefaultMargins="true"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/videoContainer"
            android:layout_width="148dp"
            android:layout_height="148dp"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <com.rezerv.app.ui.widget.CircularClipFrameLayout
                android:id="@+id/videoCircleFrame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:background="@drawable/bg_video_message_placeholder">

                <View
                    android:id="@+id/videoPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_video_message_placeholder" />

                <ImageView
                    android:id="@+id/ivVideoThumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <android.view.TextureView
                    android:id="@+id/videoTexture"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0" />
            </com.rezerv.app.ui.widget.CircularClipFrameLayout>

            <com.rezerv.app.ui.widget.RoundVideoProgressView
                android:id="@+id/videoProgress"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/tvVideoPlay"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_video_play_button"
                android:gravity="center"
                android:text="&#x25B6;"
                android:textColor="@color/ghost_text_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvVideoDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_video_duration"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:textColor="@color/ghost_text_primary"
                android:textSize="11sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxWidth="280dp"
            android:textColor="@color/ghost_text_primary"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/voiceContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnPlayVoice"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center"
                android:text="&#x25B6;"
                android:textColor="@color/ghost_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressVoice"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="110dp"
                android:layout_height="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:indeterminate="false"
                android:max="1000"
                android:progress="0"
                android:progressTint="@color/ghost_neon" />

            <TextView
                android:id="@+id/tvVoiceDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="40dp"
                android:textColor="@color/ghost_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:textColor="@color/ghost_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>

